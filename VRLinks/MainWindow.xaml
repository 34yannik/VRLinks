<Window x:Class="VRLinks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VRLinks"
        Height="600" Width="600"
        Background="#1E1E1E">

    <Window.Resources>

        <!-- TAG STYLE -->
        <Style x:Key="TagStyle" TargetType="Border">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A85FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#1E1E1E" Padding="8">
            <StackPanel>

                <Button Content="⚙"
                        Height="28"
                        Background="#2E2E2E"
                        Foreground="White"
                        Click="ConfigButton_Click"/>

                <TextBlock Text="Lists"
                           Foreground="White"
                           Margin="0,10,0,5"/>

                <ListBox Name="ListsListBox"
                         SelectionChanged="ListsListBox_SelectionChanged"
                         Background="#252525"
                         Foreground="White"/>

                <Button Content="+ Add List"
                        Background="#3A85FF"
                        Foreground="White"
                        Margin="0,5,0,0"
                        Click="AddList_Click"/>

            </StackPanel>
        </Border>

        <!-- MAIN -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SEARCH -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <Border Background="#2E2E2E" CornerRadius="5">
                    <TextBox Name="SearchTextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             Padding="6"
                             TextChanged="SearchTextBox_TextChanged"/>
                </Border>
            </StackPanel>

            <!-- LIST VIEW -->
            <ListView Grid.Row="1"
                      Name="LinksListView"
                      Background="#252525"
                      BorderThickness="0">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#333333"
                                CornerRadius="6"
                                Padding="8"
                                Margin="0,0,0,6"
                                Width="400"
                                MinHeight="100"
                                Cursor="Hand"
                                MouseDown="Item_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <!-- LINK INFO -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Url}" Foreground="Gray" FontSize="12"/>

                                    <!-- ACTIONS -->
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBox Width="120" Text="{Binding Name}" Background="#2E2E2E" Foreground="White"/>
                                        <Button Content="✔" Margin="5,0" Click="RenameButton_Click"/>
                                        <Button Content="Delete" Background="#FF4444" Foreground="White" Click="DeleteButton_Click"/>
                                    </StackPanel>

                                    <!-- TAGS -->
                                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,6,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TagStyle}">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- THUMBNAIL -->
                                <Image Grid.Column="1"
                                       Source="{Binding ThumbnailUrl}"
                                       Width="120"
                                       Height="68"
                                       VerticalAlignment="Top"
                                       Margin="5,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

            <!-- BOTTOM BAR -->
            <StackPanel Grid.Row="2" Margin="0,10,0,0">

                <StackPanel Orientation="Horizontal">

                    <TextBox Name="NameTextBox"
                             Width="90"
                             Background="#2E2E2E"
                             Foreground="White"
                             Margin="0,0,5,0"
                             Padding="5"
                             Text="Name"/>

                    <TextBox Name="UrlTextBox"
                             Width="160"
                             Background="#2E2E2E"
                             Foreground="White"
                             Margin="0,0,5,0"
                             Padding="5"
                             Text="https://"/>

                    <TextBox Name="TagsTextBox"
                             Width="80"
                             Background="#2E2E2E"
                             Foreground="White"
                             Margin="0,0,5,0"
                             Padding="5"
                             Text="tag1, tag2"/>

                    <Button Content="Add"
                            Width="60"
                            Height="30"
                            Background="#3A85FF"
                            Foreground="White"
                            Click="AddButton_Click"/>
                </StackPanel>

                <Button Content="Clear All"
                        Width="120"
                        Height="30"
                        HorizontalAlignment="Right"
                        Background="#FF4444"
                        Foreground="White"
                        Margin="0,5,0,0"
                        Click="ClearButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>