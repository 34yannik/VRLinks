<Window x:Class="VRLinks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VRLinks"
        Height="600" Width="600"
        MinHeight="300" MinWidth="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <!-- Style für ListBoxItems der Sidebar -->
        <Style x:Key="SidebarListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A85FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A7FFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKSLISTEN (Sidebar) -->
        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="6" Padding="8" Margin="0,0,10,0">
            <StackPanel>

                <!-- Überschrift + Config Button -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">

                    <!-- Config Button -->
                    <Button Content="⚙"
                        Width="28"
                        Height="28"
                        Margin="5,0,0,0"
                        FontSize="16"
                        Background="#2E2E2E"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Öffne Speicherordner"
                        Click="ConfigButton_Click"/>
                </StackPanel>
                <!-- Überschrift -->
                <TextBlock Text="Lists"
                   Foreground="White"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

                <!-- ListBox für vorhandene Listen -->
                <ListBox Name="ListsListBox"
                     SelectionChanged="ListsListBox_SelectionChanged"
                     Background="#252525"
                     BorderThickness="0"
                     Foreground="White"
                     Margin="0,0,0,8"
                     FontSize="14"
                     ItemContainerStyle="{StaticResource SidebarListItemStyle}"
                     Height="Auto"/>

                    <!-- Button zum Hinzufügen einer neuen Liste -->
                <Border Background="#3A85FF" CornerRadius="4">
                    <Button Content="+ Add List"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Cursor="Hand"
                        Height="36"
                        FontSize="16"
                        Padding="10,4"
                        Click="AddList_Click"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- HAUPTBEREICH -->
        <DockPanel Grid.Column="1" Margin="10,0,0,0">

            <!-- TOP AREA (Input) -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">

                <StackPanel Orientation="Horizontal">
                    <!-- Name -->
                    <Border Background="#2E2E2E" CornerRadius="5" Margin="0,0,5,0">
                        <TextBox Name="NameTextBox"
                                 Width="110"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="Gray"
                                 Padding="6"
                                 Text="Name"
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"/>
                    </Border>

                    <!-- URL -->
                    <Border Background="#2E2E2E" CornerRadius="5" Margin="0,0,5,0">
                        <TextBox Name="UrlTextBox"
                                 Width="180"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="Gray"
                                 Padding="6"
                                 Text="https://"
                                 GotFocus="TextBox_GotFocus"
                                 LostFocus="TextBox_LostFocus"/>
                    </Border>

                    <!-- Add Button -->
                    <Border Background="#3A85FF" CornerRadius="5">
                        <Button Content="Add"
                                Width="60"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Cursor="Hand"
                                Click="AddButton_Click"/>
                    </Border>
                </StackPanel>

                <!-- Clear Button -->
                <Border Background="#FF4444" CornerRadius="5" HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="Clear All"
                            Width="100"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="White"
                            Cursor="Hand"
                            Click="ClearButton_Click"/>
                </Border>

            </StackPanel>

            <!-- LINKS LIST -->
            <ListView Name="LinksListView"
                      Background="#252525"
                      BorderThickness="0">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#333333"
                CornerRadius="6"
                Padding="8"
                Margin="0,0,0,6">

                            <StackPanel>

                                <!-- ERSTE REIHE: Name + Copy -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MaxWidth="180"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Name}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Name}"/>

                                    <Border Grid.Column="1" Background="#3A85FF" CornerRadius="4">
                                        <Button Content="Copy"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Padding="6,2"
                                Cursor="Hand"
                                Click="CopyButton_Click"/>
                                    </Border>
                                </Grid>

                                <!-- ZWEITE REIHE: URL -->
                                <TextBlock Text="{Binding Url}"
                           Foreground="LightGray"
                           FontSize="12"
                           Margin="0,5,0,0"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Url}"/>

                                <!-- DRITTE REIHE: Rename + Delete -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Border Background="#2E2E2E" CornerRadius="4">
                                        <TextBox Width="120"
                                 Text="{Binding Name, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Padding="4"/>
                                    </Border>

                                    <Border Background="#3A85FF" CornerRadius="4" Margin="5,0,0,0">
                                        <Button Content="✔"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Padding="6,2"
                                Cursor="Hand"
                                Click="RenameButton_Click"/>
                                    </Border>

                                    <Border Background="#FF4444" CornerRadius="4" Margin="10,0,0,0">
                                        <Button Content="Delete"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Padding="6,2"
                                Cursor="Hand"
                                Click="DeleteButton_Click"/>
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </DockPanel>
    </Grid>
</Window>